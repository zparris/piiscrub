<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>PIIScrub</string>

  <key>CFBundleExecutable</key>
  <string>PIIScrub</string>

  <key>CFBundleIdentifier</key>
  <string>com.zparris.piiscrub</string>

  <key>CFBundleName</key>
  <string>PIIScrub</string>

  <key>CFBundlePackageType</key>
  <string>APPL</string>

  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>

  <key>CFBundleVersion</key>
  <string>0.1.0</string>

  <!-- Allow the app to open from any location without Gatekeeper quarantine prompt -->
  <key>LSEnvironment</key>
  <dict>
    <key>PYTHONDONTWRITEBYTECODE</key>
    <string>1</string>
  </dict>

  <!-- Suppress dock icon — this is a background/menu-bar-style app -->
  <key>LSUIElement</key>
  <false/>

  <key>NSHumanReadableCopyright</key>
  <string>Copyright © 2024 Zahir Parris. MIT License.</string>

  <!-- Minimum macOS version: 12 Monterey (supports Apple Silicon via Rosetta on this Intel build) -->
  <key>LSMinimumSystemVersion</key>
  <string>12.0</string>
</dict>
</plist>
